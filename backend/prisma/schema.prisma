generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum PricingModel {
  FREE
  FREEMIUM
  PAID
  FREE_TRIAL
}

enum BillingFrequency {
  MONTHLY
  YEARLY
  ONE_TIME
  NA
}

// ---- Stub models owned by other modules ----
// Module 4 (Companies) and Module 11 (Auth) will extend these.
// Do not add fields here beyond what Module 3 needs for its relations.

model Company {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  logoUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  tools Tool[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  image     String?
  role      String   @default("USER")
  emailVerified DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  reviews   Review[]
  bookmarks Bookmark[]
  accounts  Account[]
  sessions  Session[]
}

// ---- Module 3: AI Tools ----

model Tool {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  logoUrl     String?
  description String
  websiteUrl  String
  screenshots String[] @default([])
  features    String[] @default([])

  pricingModel     PricingModel
  pricingAmount    Decimal?         @db.Decimal(10, 2)
  billingFrequency BillingFrequency @default(NA)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  categories ToolCategory[]
  tags       ToolTag[]

  reviews   Review[]
  bookmarks Bookmark[]

  alternatives  Tool[] @relation("ToolAlternatives")
  alternativeOf Tool[] @relation("ToolAlternatives")

  // Denormalized for fast listing-page sort/display. Recomputed by the
  // reviews API on every create/update/delete — see lib/reviews.ts.
  avgRating   Float @default(0)
  reviewCount Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([companyId])
@@index([pricingModel])
@@index([createdAt])
@@index([avgRating])
}

model Category {
  id   String @id @default(cuid())
  slug String @unique
  name String

  tools ToolCategory[]
}

model Tag {
  id   String @id @default(cuid())
  slug String @unique
  name String

  tools ToolTag[]
}

model ToolCategory {
  toolId     String
  categoryId String

  tool     Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([toolId, categoryId])
  @@index([categoryId])
}

model ToolTag {
  toolId String
  tagId  String

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([toolId, tagId])
  @@index([tagId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([toolId, userId])
@@index([toolId])
@@index([userId])
@@index([rating])
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([toolId, userId])
@@index([toolId])
@@index([userId])
}

model AIModel {
  id            String   @id @default(cuid())
  name          String
  creator       String
  contextWindow String
  parameterSize String
  modality      String
  releaseDate   String
  description   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

// ---- News module ----

model Publisher {
  id               String   @id @default(cuid())
  name             String
  domain           String   @unique
  website          String
  logoUrl          String?
  faviconUrl       String?
  colorHex         String?
  followersLabel   String?
  credibilityScore Float    @default(0.8)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  articles News[]

  @@index([name])
}

model Topic {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  articles News[]
}

model News {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  dek        String
  aiSummary  String
  articleUrl String   @unique

  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id])

  category   String
  filterTags String[] @default([])
  topics     Topic[]

  publishedAt DateTime
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookmarks NewsBookmark[]
  votes     NewsVote[]
  comments  NewsComment[]

  @@index([publishedAt])
  @@index([publisherId])
  @@index([category])
}

model NewsBookmark {
  id        String   @id @default(cuid())
  articleId String
  article   News     @relation(fields: [articleId], references: [id])
  clientId  String
  createdAt DateTime @default(now())

  @@unique([articleId, clientId])
}

model NewsVote {
  id        String   @id @default(cuid())
  articleId String
  article   News     @relation(fields: [articleId], references: [id])
  clientId  String
  value     Int
  createdAt DateTime @default(now())

  @@unique([articleId, clientId])
}

model NewsComment {
  id         String   @id @default(cuid())
  articleId  String
  article    News     @relation(fields: [articleId], references: [id])
  clientId   String
  authorName String   @default("Anonymous")
  body       String
  createdAt  DateTime @default(now())

  @@index([articleId])
}

model Repository {
  id          String   @id @default(cuid())
  name        String
  owner       String
  stars       Int
  language    String
  description String
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

// Synced from live production DB via `prisma db pull` on 2026-07-12 — this
// model was migrated directly to prod by another module without ever being
// committed here. Kept verbatim; not owned by this module, do not alter.
model Video {
  id              String   @id @default(cuid())
  title           String
  publishedAt     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  accent          String
  authorAvatar    String
  authorName      String
  description     String
  durationSeconds Int
  likes           Int
  slug            String   @unique
  tags            String[] @default([])
  thumbnail       String
  toolCategory    String
  toolName        String
  youtubeId       String   @unique
  views           Int

  @@index([publishedAt])
  @@index([toolCategory])
  @@index([views])
}

model Robot {
  id           String   @id @default(cuid())
  name         String
  category     String
  manufacturer String
  year         String
  description  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Device {
  id           String   @id @default(cuid())
  name         String
  category     String
  manufacturer String
  year         String
  description  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}// ---- Auth Module ----

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LeaderboardCompany {
  id            String @id
  name          String
  rank          Int
  growth        Float
  funding       String
  headquarters  String
  productsCount Int
  modelsCount   Int
  votes         Int
  rating        Float
  saves         Int
  description   String
  visits        String
}

model LeaderboardModel {
  id             String  @id
  name           String
  provider       String
  category       String
  rank           Int
  growth         Float
  contextWindow  String
  pricing        String
  eloRating      Int
  benchmarkScore Float
  openSource     Boolean
  votes          Int
  rating         Float
  saves          Int
  description    String
  visits         String
}

model LeaderboardTool {
  id          String @id
  name        String
  category    String
  tags        String
  rank        Int
  growth      Float
  votes       Int
  rating      Float
  saves       Int
  url         String
  description String
  pricing     String
  visits      String
  addedDate   String
}

